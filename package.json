{
  "name": "vehiclevo-licensing-system",
  "version": "0.1.0",
  "private": true,
  "description": "Vehiclevo centralized licensing platform (server, SDK, shared)",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/sdk",
    "packages/admin-web"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --build --noEmit",
    "keygen": "node --loader ts-node/esm packages/server/scripts/keygen.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
