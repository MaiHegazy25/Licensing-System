# Copy to .env and fill in. NEVER commit .env or real secrets.

# --- Server ---
LICENSING_HTTP_PORT=8080
LICENSING_ENV=development
# Floating/concurrent seat lease duration (seconds). Clients must heartbeat
# within this window; a crashed client's seat is reclaimed after it elapses.
FLOATING_LEASE_TTL_SECONDS=900
# Max validity (days) of an offline activation token when the license has no
# expiry (perpetual). Expiring licenses bound the offline token to their expiry.
OFFLINE_TOKEN_MAX_DAYS=365
# Per-IP fixed-window rate limit for public endpoints (activate/validate/
# offline/floating/deactivate). 0 disables. Per-instance baseline; use a
# shared-store or gateway limiter for multi-instance production.
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_SECONDS=60

# --- Database ---
# Local dev via docker-compose; use a secrets manager in staging/production.
DATABASE_URL=postgres://licensing:licensing@localhost:5432/licensing

# --- Signing keys ---
# Provider: "local" (dev only, keys on disk) or "kms" (Azure Key Vault / AWS KMS in prod).
SIGNING_PROVIDER=local
# For local provider: directory holding generated dev keypairs (gitignored).
# Generate with: npm run keygen
LOCAL_KEYS_DIR=./keys/local
# The keyId the server should sign new tokens with (rotation = change this).
ACTIVE_SIGNING_KEY_ID=

# For SIGNING_PROVIDER=kms (production; private keys stay in the vault/HSM).
# Reference implementation: Azure Key Vault (EdDSA/Ed25519) over REST.
# KMS_PROVIDER=azure
# AZURE_KEY_VAULT_URL=https://<vault>.vault.azure.net
# Map each kid -> vault key name+version:
# KMS_KEYS={"key-2026-01":{"name":"licensing-signing","version":"<key-version>"}}
# Azure AD client-credentials (from a secrets manager, never hard-coded):
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# Token issuer/audience claims
TOKEN_ISSUER=https://licensing.vehiclevo.example
TOKEN_AUDIENCE=vehiclevo-products

# --- Activation code hashing pepper ---
# In production this MUST come from a secrets manager, not .env.
ACTIVATION_CODE_PEPPER=

# --- Admin authentication (dev/slice) ---
# Legacy single key -> subject "admin", role system_admin:
ADMIN_API_KEY=
# OR multiple roled keys (JSON). Roles: system_admin | license_admin |
# sales_ops | support | auditor. Keys are secrets — use a secrets manager in
# real environments; production replaces this with OIDC (Entra ID / Keycloak).
# ADMIN_API_KEYS=[{"subject":"alice","role":"auditor","key":"CHANGE_ME"}]
ADMIN_API_KEYS=
# Allowed origin for the admin SPA (CORS). Default "*" for dev only.
ADMIN_WEB_ORIGIN=*

# --- Authentication mode ---
# "apikey" (default; uses ADMIN_API_KEY/ADMIN_API_KEYS above) or "oidc".
AUTH_MODE=apikey
# OIDC (production): validate IdP-issued JWT access tokens (Entra ID / Keycloak).
# OIDC_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0
# OIDC_AUDIENCE=api://licensing
# OIDC_JWKS_URI=https://login.microsoftonline.com/<tenant>/discovery/v2.0/keys
# OIDC_ROLE_CLAIM=roles
# Map IdP app-roles/groups -> our roles (system_admin|license_admin|sales_ops|support|auditor):
# OIDC_ROLE_MAP={"Licensing.Admin":"license_admin","Licensing.Audit":"auditor"}

# --- Customer portal authentication (dev/slice) ---
# Maps customer access keys to a customerId scope. Keys are secrets (secrets
# manager in real environments); production uses a customer OIDC/B2C resolver.
# CUSTOMER_API_KEYS=[{"customerId":"acme","subject":"admin@acme","key":"CHANGE_ME"}]
CUSTOMER_API_KEYS=
